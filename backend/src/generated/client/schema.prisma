generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String
  category    String
  description String?
  date        DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
